# object-detection-custom-inference-onnx — runs on CPU or NVIDIA GPU via ONNX Runtime CUDA EP
#
# For Jetson (aarch64) with GPU:
#   Build on device or use a Jetson-compatible base image with CUDA.
#
# For CPU-only (x86_64 or aarch64 without GPU):
#   docker buildx build --platform linux/amd64 -t object-detection-custom-inference-onnx:cpu .
#
# For NVIDIA GPU (x86_64):
#   docker build --build-arg BASE=nvcr.io/nvidia/cuda:12.4.1-cudnn-runtime-ubi9 -t object-detection-custom-inference-onnx:cuda .

#ARG BASE=python:3.11-slim
ARG BASE=nvcr.io/nvidia/cuda:12.4.1-cudnn-runtime-ubi9
FROM ${BASE}

RUN dnf install -y \
        python3 \
        python3-pip \
        mesa-libGL \
        glib2 \
    && dnf clean all

# Optional but recommended: ensure pip is up to date
RUN python3 -m pip install --upgrade pip

# Install ONNX Runtime — CPU build (works everywhere)
# For CUDA EP on x86, replace with: onnxruntime-gpu
#ARG ONNXRUNTIME_PKG=onnxruntime
ARG ONNXRUNTIME_PKG=onnxruntime-gpu
RUN pip install --no-cache-dir \
        ${ONNXRUNTIME_PKG} \
        opencv-python-headless \
        pyzmq \
        numpy

WORKDIR /app
COPY inference.py shm_frame.py ./

# Model directory (mount your .onnx here)
RUN mkdir -p /opt/models
#Default model
COPY yolo26n.onnx /opt/models/model.onnx

CMD ["python3", "-u", "inference.py"]
