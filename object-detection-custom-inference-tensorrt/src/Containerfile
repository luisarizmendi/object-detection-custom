# object-detection-custom-inference-tensorrt — desktop/server GPU (x86_64) or generic ARM64
#
# Uses the NVIDIA TensorRT container from NGC, which supports x86_64 natively
# and arm64 (non-Jetson, e.g. Graviton or Ampere-based servers).
# For Jetson (JetPack), use the object-detection-custom-inference-tensorrt-jetson image instead.
#
# Build for x86_64 (default):
#   podman build -t object-detection-custom-inference-tensorrt:latest .
#
# Build for generic arm64:
#   podman build --platform linux/arm64 -t object-detection-custom-inference-tensorrt:latest .
#
# Dependencies:
#   cuda-python  — official NVIDIA replacement for pycuda; compatible with
#                  NumPy 2.x and TensorRT 10.x  (pycuda is NOT installed)
#   numpy<2      — pin; TRT's own bundled numpy may still be 1.x on older
#                  bases, and mixing 1.x/2.x in native extensions causes crashes

FROM nvcr.io/nvidia/tensorrt:24.05-py3

RUN apt-get update && apt-get install -y --no-install-recommends \
        python3-pip python3-dev \
        libgl1 libglib2.0-0 \
    && rm -rf /var/lib/apt/lists/*

# Install in a single layer; pin numpy<2 to avoid ABI breakage
# in any native extensions that may still ship in the base image.
# cuda-python must be <13: the 13.x series split into cuda-python +
# cuda-bindings and changed the import API. Pinning to 12.x keeps
# "from cuda import cudart" working and matches the CUDA 12.4 runtime
# bundled in the tensorrt:24.05-py3 base image.
RUN pip3 install --no-cache-dir \
        "numpy<2" \
        opencv-python-headless \
        pyzmq \
        "cuda-python>=12.4,<13" \
        onnxruntime

WORKDIR /app
COPY inference.py shm_frame.py ./

RUN mkdir -p /opt/models

CMD ["python3", "-u", "inference.py"]